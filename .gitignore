# ============================================
# UnoOne Agent — .gitignore
# ============================================

# --- IDE ---
.idea/
.vscode/
*.iml
*.swp
*.swo

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# --- Android Build ---
build/
*/build/
**/build/
.gradle/
**/.gradle/
local.properties
*.apk
*.aab
*.ap_
*.dex

# --- Android Studio ---
.navigation/
captures/
*.hprof

# --- Kotlin ---
*.kt.swp

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# --- Node / browser test output ---
node_modules/
**/node_modules/
dist/
**/dist/
dist-worker/
**/dist-worker/
test-results/
**/test-results/
playwright-report/
**/playwright-report/

# Page Agent is generated by `npm run bundle:android` and rebuilt in Android CI.
android-app/UnoOneAgent/securebrowser/src/main/assets/page-agent/

# --- Models (large binaries — push via ADB, never commit) ---
models/*/
!models/.gitkeep

# --- Logs and local device diagnostics ---
*.log
artifacts/

# --- Keystores & Secrets ---
*.jks
*.keystore
keystore.properties
.env
credentials.json
secrets.properties

# --- Gradle ---
.gradle-wrapper.jar

# --- Misc ---
*.bak
*.tmp
