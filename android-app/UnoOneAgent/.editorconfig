root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.kt]
indent_size = 4
continuation_indent_size = 4

[*.xml]
indent_size = 4

[*.gradle.kts]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.yml]
indent_size = 2