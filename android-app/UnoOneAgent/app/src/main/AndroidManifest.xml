<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.unoone.agent">

    <!-- Basic Connectivity -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Voice & Audio -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <!-- Hardware & Media -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <!-- MANAGE_EXTERNAL_STORAGE removed: app uses getExternalFilesDir() which is app-private
         and does not require this permission. This permission would trigger Google Play review. -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Background Processing -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- System Integration & Control -->
    <!-- READ_CONTACTS removed: declared but never used in code. Will trigger Play review. -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <!-- QUERY_ALL_PACKAGES removed: PackageResolver uses a hardcoded 10-app map, no runtime
         package query needed. This permission is sensitive and causes Play review rejection.
         Use queryIntentActivities() with specific intents instead. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Hardware Features -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.microphone" android:required="true" />
    <uses-feature android:name="android.hardware.bluetooth" android:required="false" />

    <!-- Android 11+ package visibility for the small, curated offline app launcher map. This is
         intentionally exact-package visibility, not QUERY_ALL_PACKAGES. -->
    <queries>
        <package android:name="com.whatsapp" />
        <package android:name="com.whatsapp.w4b" />
        <package android:name="com.google.android.gm" />
        <package android:name="com.google.android.calendar" />
        <package android:name="com.xiaomi.calendar" />
        <package android:name="com.android.chrome" />
        <package android:name="com.android.camera" />
        <package android:name="com.google.android.youtube" />
        <package android:name="com.google.android.apps.maps" />
        <package android:name="com.android.vending" />
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.APP_CALENDAR" />
        </intent>
        <intent>
            <action android:name="android.intent.action.INSERT" />
            <data android:mimeType="vnd.android.cursor.dir/event" />
        </intent>
        <intent>
            <action android:name="android.intent.action.SENDTO" />
            <data android:scheme="mailto" />
        </intent>
    </queries>

    <application
        android:name=".UnoOneApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.UnoOne">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.UnoOne"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Transparent activity used to obtain MediaProjection permission for screenshot OCR -->
        <activity
            android:name=".screenshot.ScreenshotPermissionActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true"
            android:noHistory="true" />

        <service
            android:name=".screenshot.MediaProjectionService"
            android:foregroundServiceType="mediaProjection"
            android:exported="false" />

        <!-- Floating Agent Bubble — foreground service to prevent system kill -->
        <service
            android:name=".FloatingAgentService"
            android:foregroundServiceType="specialUse"
            android:exported="false" />

        <!-- The "Hands" of the Agent - Accessibility Service -->
        <service
            android:name="com.unoone.agent.accessibilitycontrol.UnoOneAccessibilityService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="false">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Background Voice Processing Service -->
        <service
            android:name="com.unoone.agent.voice.VoiceService"
            android:foregroundServiceType="microphone"
            android:exported="false" />

    </application>

</manifest>
